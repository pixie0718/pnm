// ─────────────────────────────────────────────
// ShiftIndia — Packers & Movers Marketplace
// Prisma schema (MySQL)
//
// Only dynamic data lives here. Static content
// (cities, reviews, stats, services, faqs, SEO)
// lives in /data as JSON files.
// ─────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  relationMode = "prisma"
}

// ─────────────────────────────────────────────
// INQUIRIES — customer quote requests
// ─────────────────────────────────────────────
enum InquiryStatus {
  new
  contacted
  quoted
  booked
  cancelled
}

model Inquiry {
  id            Int       @id @default(autoincrement())
  name          String?   @db.VarChar(120)
  phone         String?   @db.VarChar(20)
  email         String?   @db.VarChar(160)
  pickupCity    String    @map("pickup_city") @db.VarChar(120)
  pickupAddress String?   @map("pickup_address") @db.Text
  dropCity      String    @map("drop_city") @db.VarChar(120)
  dropAddress   String?   @map("drop_address") @db.Text
  houseSize     String    @map("house_size") @db.VarChar(20)
  movingDate    DateTime? @map("moving_date") @db.Date
  notes         String?   @db.Text
  needLabour    Boolean   @default(false) @map("need_labour")
  extraPacking  Boolean   @default(false) @map("extra_packing")
  onlyMoving    Boolean   @default(false) @map("only_moving")
  source        String?   @default("website") @db.VarChar(60)
  status        InquiryStatus @default(new)

  customerId Int?      @map("customer_id")
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  quotes Quote[]

  @@index([status])
  @@index([createdAt])
  @@index([customerId])
  @@map("inquiries")
}

// ─────────────────────────────────────────────
// QUOTES — responses sent to inquiries
// ─────────────────────────────────────────────
enum QuoteStatus {
  draft
  sent
  accepted
  rejected
}

model Quote {
  id         Int     @id @default(autoincrement())
  inquiryId  Int     @map("inquiry_id")
  vendorName String  @map("vendor_name") @db.VarChar(180)
  priceLow   Int     @map("price_low")
  priceHigh  Int     @map("price_high")
  eta        String? @db.VarChar(60)
  features   Json?
  notes      String? @db.Text
  status     QuoteStatus @default(draft)

  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  inquiry Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
  @@index([status])
  @@map("quotes")
}

// ─────────────────────────────────────────────
// BLOG POSTS
// ─────────────────────────────────────────────
enum BlogStatus {
  draft
  published
}

model BlogPost {
  id               Int        @id @default(autoincrement())
  title            String     @db.VarChar(255)
  slug             String     @unique @db.VarChar(255)
  excerpt          String?    @db.Text
  content          String     @db.LongText
  coverImage       String?    @map("cover_image") @db.VarChar(500)
  status           BlogStatus @default(draft)
  author           String     @default("Admin") @db.VarChar(120)
  publishedAt      DateTime?  @map("published_at")

  // SEO
  metaTitle        String?    @map("meta_title") @db.VarChar(60)
  metaDescription  String?    @map("meta_description") @db.VarChar(160)
  metaKeywords     String?    @map("meta_keywords") @db.VarChar(500)
  focusKeyword     String?    @map("focus_keyword") @db.VarChar(100)
  ogImage          String?    @map("og_image") @db.VarChar(500)
  canonicalUrl     String?    @map("canonical_url") @db.VarChar(500)

  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  @@index([status])
  @@index([slug])
  @@map("blog_posts")
}

// ─────────────────────────────────────────────
// CUSTOMERS — people who booked or got quoted
// ─────────────────────────────────────────────
model Customer {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(120)
  phone        String   @unique @db.VarChar(20)
  email        String?  @unique @db.VarChar(160)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  city         String?  @db.VarChar(120)
  notes        String?  @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  inquiries Inquiry[]

  @@index([phone])
  @@map("customers")
}
